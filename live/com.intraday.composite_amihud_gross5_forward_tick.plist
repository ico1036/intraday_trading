<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.intraday.composite_amihud_gross5_forward_tick</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/jj_home/Git/intraday_trading &amp;&amp; SEAL_OPEN=1 MPLCONFIGDIR=/private/tmp/matplotlib-cache /Users/jj_home/.local/bin/uv run python scripts/run_live_composite_amihud_gross5_tick.py --as-of $(date -u +%Y-%m-%d) --sync-data &gt;&gt; /tmp/composite_amihud_gross5_forward_cron.log 2&gt;&amp;1</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>20</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/tmp/composite_amihud_gross5_forward_launchd.out</string>

  <key>StandardErrorPath</key>
  <string>/tmp/composite_amihud_gross5_forward_launchd.err</string>

  <key>WorkingDirectory</key>
  <string>/Users/jj_home/Git/intraday_trading</string>
</dict>
</plist>
